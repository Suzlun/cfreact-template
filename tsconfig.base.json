{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": ".",
    "paths": {
      "@cfreact-template/frontend": ["./packages/frontend/src/app/index.ts"],
      "@cfreact-template/frontend/app": ["./packages/frontend/src/app/index.ts"],
      "@cfreact-template/frontend/app/*": ["./packages/frontend/src/app/*"],
      "@cfreact-template/frontend/domain": ["./packages/frontend/src/domain/index.ts"],
      "@cfreact-template/frontend/domain/*": ["./packages/frontend/src/domain/*"],
      "@cfreact-template/frontend/api": ["./packages/frontend/src/api/index.ts"],
      "@cfreact-template/frontend/api/*": ["./packages/frontend/src/api/*"],
      "@cfreact-template/frontend/ui": ["./packages/frontend/src/ui/index.ts"],
      "@cfreact-template/frontend/ui/*": ["./packages/frontend/src/ui/*"],
      "@cfreact-template/backend": ["./packages/backend/src/entry/index.ts"],
      "@cfreact-template/backend/types": ["./packages/backend/src/types/index.ts"],
      "@cfreact-template/backend/types/*": ["./packages/backend/src/types/*"],
      "@cfreact-template/backend/domain": ["./packages/backend/src/domain/index.ts"],
      "@cfreact-template/backend/domain/*": ["./packages/backend/src/domain/*"],
      "@cfreact-template/backend/usecases": ["./packages/backend/src/usecases/index.ts"],
      "@cfreact-template/backend/usecases/*": ["./packages/backend/src/usecases/*"],
      "@cfreact-template/backend/http": ["./packages/backend/src/http/index.ts"],
      "@cfreact-template/backend/http/*": ["./packages/backend/src/http/*"],
      "@cfreact-template/backend/persistence": ["./packages/backend/src/persistence/index.ts"],
      "@cfreact-template/backend/persistence/*": ["./packages/backend/src/persistence/*"],
      "@cfreact-template/backend/app": ["./packages/backend/src/app/index.ts"],
      "@cfreact-template/backend/app/*": ["./packages/backend/src/app/*"],
      "@cfreact-template/backend/entry": ["./packages/backend/src/entry/index.ts"],
      "@cfreact-template/backend/entry/*": ["./packages/backend/src/entry/*"],
      "@cfreact-template/backend/drizzle": ["./packages/backend/src/drizzle/index.ts"],
      "@cfreact-template/backend/drizzle/*": ["./packages/backend/src/drizzle/*"]
    },
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "exclude": ["node_modules", "dist", "build", ".wrangler"]
}
