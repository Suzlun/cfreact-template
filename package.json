{
  "name": "cfreact-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Full-stack template for Cloudflare Workers with React, Hono, and Drizzle ORM",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "dev:client": "pnpm --filter @cfreact-template-client/app dev",
    "dev:server": "pnpm --filter @cfreact-template-server/entry dev",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "build:client": "pnpm --filter @cfreact-template-client/app build",
    "build:server": "pnpm --filter @cfreact-template-server/entry build",
    "build": "pnpm build:server && pnpm build:client",
    "check": "pnpm --filter \"./packages/**\" check",
    "gen:swagger": "pnpm --filter @cfreact-template-server/entry openapi:gen",
    "gen:api-sdk": "pnpm gen:swagger && pnpm --filter @cfreact-template-client/api gen",
    "migrate:generate": "drizzle-kit generate",
    "migrate:apply": "wrangler d1 execute cfreact-template-db --local --file=./drizzle/migrations/<migration-file>.sql",
    "migrate:studio": "drizzle-kit studio",
    "deploy": "pnpm build && wrangler deploy",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:client": "pnpm --filter @cfreact-template-client/app test",
    "test:server": "vitest --project server-http",
    "test:ui-package": "vitest --project ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.56.1",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.9.3",
    "@vitest/ui": "^4.0.9",
    "concurrently": "^9.1.2",
    "dompurify": "^3.3.0",
    "drizzle-kit": "^0.24.2",
    "eslint": "^9.15.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.2.0",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^4.0.9",
    "wrangler": "^4.0.1"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7"
  }
}
