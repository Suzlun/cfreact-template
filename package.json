{
  "name": "cfreact-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Full-stack template for Cloudflare Workers with React, Hono, and Drizzle ORM",
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "dev:client": "pnpm --filter @cfreact-template/client dev",
    "dev:server": "pnpm --filter @cfreact-template/server dev",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "build:client": "pnpm --filter @cfreact-template/client build",
    "build:server": "pnpm --filter @cfreact-template/server build",
    "build": "pnpm build:server && pnpm build:client",
    "check": "pnpm --filter \"./packages/**\" check",
    "migrate:generate": "drizzle-kit generate",
    "migrate:apply": "wrangler d1 execute cfreact-template-db --local --file=./drizzle/migrations/<migration-file>.sql",
    "migrate:studio": "drizzle-kit studio",
    "deploy": "pnpm build && wrangler deploy",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.15.0",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.9.3",
    "concurrently": "^9.1.2",
    "dompurify": "^3.3.0",
    "drizzle-kit": "^0.24.2",
    "eslint": "^9.15.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.15.0",
    "wrangler": "^4.0.1"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7"
  }
}
