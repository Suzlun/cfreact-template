{
  "name": "cfreact-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Full-stack template for Cloudflare Workers with React, Hono, and Drizzle ORM",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "dev:client": "pnpm --filter @cfreact-template-frontend/app dev",
    "dev:server": "pnpm --filter @cfreact-template-backend/entry dev",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "build:client": "pnpm --filter @cfreact-template-frontend/app build",
    "build:server": "pnpm --filter @cfreact-template-backend/entry build",
    "build": "pnpm build:server && pnpm build:client",
    "check": "pnpm --filter \"./packages/**\" check",
    "gen:openapi": "pnpm --filter @cfreact-template/typespec gen:openapi && prettier --write packages/typespec/openapi/openapi.json",
    "gen:swagger": "pnpm gen:openapi",
    "gen:api-sdk": "pnpm gen:openapi && pnpm --filter @cfreact-template-frontend/api gen && prettier --write packages/frontend/api/src/generated/client.ts",
    "check:codegen": "pnpm gen:api-sdk && git ls-files --error-unmatch packages/typespec/openapi/openapi.json packages/frontend/api/src/generated/client.ts >/dev/null && git diff --exit-code -- packages/typespec/openapi/openapi.json packages/frontend/api/src/generated/client.ts",
    "migrate:generate": "drizzle-kit generate",
    "migrate:apply": "wrangler d1 execute cfreact-template-db --local --file=./drizzle/migrations/<migration-file>.sql",
    "migrate:studio": "drizzle-kit studio",
    "deploy": "pnpm build && wrangler deploy",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:client": "pnpm --filter @cfreact-template-frontend/app test",
    "test:server": "vitest run --project backend-http",
    "test:ui-package": "vitest run --project frontend-ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "pnpm lint:eslint && pnpm lint:openspec",
    "lint:eslint": "eslint .",
    "lint:openspec": "pnpm exec openspec validate --all --strict && node scripts/openspec/verify-scenario-coverage.mjs",
    "format": "pnpm --filter @cfreact-template/typespec format && prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "pnpm --filter @cfreact-template/typespec format:check && prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.1.1",
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@cloudflare/vitest-pool-workers": "^0.12.10",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.0.3",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^9.2.1",
    "dompurify": "^3.3.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.3.1",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.57.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3",
      "@tanstack/react-query": "5.90.16"
    }
  }
}
