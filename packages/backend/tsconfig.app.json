{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/app",
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@cfreact-template/backend": ["./src/__forbidden__/backend.ts"],
      "@cfreact-template/backend/app": ["./src/app/index.ts"],
      "@cfreact-template/backend/app/*": ["./src/app/*"],
      "@cfreact-template/backend/domain": ["./src/domain/index.ts"],
      "@cfreact-template/backend/domain/*": ["./src/domain/*"],
      "@cfreact-template/backend/drizzle": ["./src/__forbidden__/drizzle.ts"],
      "@cfreact-template/backend/drizzle/*": ["./src/__forbidden__/drizzle/*"],
      "@cfreact-template/backend/entry": ["./src/__forbidden__/entry.ts"],
      "@cfreact-template/backend/entry/*": ["./src/__forbidden__/entry/*"],
      "@cfreact-template/backend/http": ["./src/http/index.ts"],
      "@cfreact-template/backend/http/*": ["./src/http/*"],
      "@cfreact-template/backend/persistence": ["./src/persistence/index.ts"],
      "@cfreact-template/backend/persistence/*": ["./src/persistence/*"],
      "@cfreact-template/backend/types": ["./src/types/index.ts"],
      "@cfreact-template/backend/types/*": ["./src/types/*"],
      "@cfreact-template/backend/usecases": ["./src/usecases/index.ts"],
      "@cfreact-template/backend/usecases/*": ["./src/usecases/*"]
    }
  },
  "include": ["src/app/**/*"]
}
