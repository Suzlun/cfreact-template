{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist/entry",
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@cfreact-template/backend": ["./src/entry/index.ts"],
      "@cfreact-template/backend/app": ["./src/app/index.ts"],
      "@cfreact-template/backend/app/*": ["./src/app/*"],
      "@cfreact-template/backend/domain": ["./src/__forbidden__/domain.ts"],
      "@cfreact-template/backend/domain/*": ["./src/__forbidden__/domain/*"],
      "@cfreact-template/backend/drizzle": ["./src/__forbidden__/drizzle.ts"],
      "@cfreact-template/backend/drizzle/*": ["./src/__forbidden__/drizzle/*"],
      "@cfreact-template/backend/entry": ["./src/entry/index.ts"],
      "@cfreact-template/backend/entry/*": ["./src/entry/*"],
      "@cfreact-template/backend/http": ["./src/__forbidden__/http.ts"],
      "@cfreact-template/backend/http/*": ["./src/__forbidden__/http/*"],
      "@cfreact-template/backend/persistence": ["./src/__forbidden__/persistence.ts"],
      "@cfreact-template/backend/persistence/*": ["./src/__forbidden__/persistence/*"],
      "@cfreact-template/backend/types": ["./src/__forbidden__/types.ts"],
      "@cfreact-template/backend/types/*": ["./src/__forbidden__/types/*"],
      "@cfreact-template/backend/usecases": ["./src/__forbidden__/usecases.ts"],
      "@cfreact-template/backend/usecases/*": ["./src/__forbidden__/usecases/*"]
    }
  },
  "include": ["src/entry/**/*"]
}
