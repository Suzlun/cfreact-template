{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist/ui",
    "paths": {
      "@cfreact-template/frontend": ["./src/__forbidden__/frontend.ts"],
      "@cfreact-template/frontend/app": ["./src/__forbidden__/app.ts"],
      "@cfreact-template/frontend/app/*": ["./src/__forbidden__/app/*"],
      "@cfreact-template/frontend/api": ["./src/__forbidden__/api.ts"],
      "@cfreact-template/frontend/api/*": ["./src/__forbidden__/api/*"],
      "@cfreact-template/frontend/domain": ["./src/__forbidden__/domain.ts"],
      "@cfreact-template/frontend/domain/*": ["./src/__forbidden__/domain/*"],
      "@cfreact-template/frontend/ui": ["./src/ui/index.ts"],
      "@cfreact-template/frontend/ui/*": ["./src/ui/*"]
    }
  },
  "include": ["src/ui/**/*"]
}
