{
  "name": "@cfreact-template/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app/index.ts",
    "./app": "./src/app/index.ts",
    "./app/app": "./src/app/app.tsx",
    "./app/router": "./src/app/router.tsx",
    "./app/components/layout/AppLayout": "./src/app/components/layout/AppLayout.tsx",
    "./app/pages/home/HomePage": "./src/app/pages/home/HomePage.tsx",
    "./app/pages/users/UsersPage": "./src/app/pages/users/UsersPage.tsx",
    "./app/tests/mocks/handlers": "./src/app/tests/mocks/handlers.ts",
    "./app/tests/mocks/server": "./src/app/tests/mocks/server.ts",
    "./app/tests/utils/test-utils": "./src/app/tests/utils/test-utils.tsx",
    "./app/*": "./src/app/*.ts",
    "./app/*.tsx": "./src/app/*.tsx",
    "./api": "./src/api/index.ts",
    "./api/api": "./src/api/api/index.ts",
    "./api/api/client": "./src/api/api/client.ts",
    "./api/*": "./src/api/*.ts",
    "./api/generated": "./src/api/generated/client.ts",
    "./api/sdk": "./src/api/sdk.ts",
    "./api/types": "./src/api/types/index.ts",
    "./api/types/hello": "./src/api/types/hello.ts",
    "./api/types/users": "./src/api/types/users.ts",
    "./domain": "./src/domain/index.ts",
    "./domain/hooks/hello/useHello": "./src/domain/hooks/hello/useHello.ts",
    "./domain/hooks/users/useUsers": "./src/domain/hooks/users/useUsers.ts",
    "./domain/providers/QueryProvider": "./src/domain/providers/QueryProvider.tsx",
    "./domain/*": "./src/domain/*.ts",
    "./domain/hooks/hello": "./src/domain/hooks/hello/index.ts",
    "./domain/hooks/users": "./src/domain/hooks/users/index.ts"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm check && vite build",
    "preview": "vite preview",
    "check": "pnpm --filter @cfreact-template/ui check && pnpm check:api && pnpm check:domain && pnpm check:app",
    "check:api": "tsc --noEmit -p tsconfig.api.json",
    "check:domain": "tsc --noEmit -p tsconfig.domain.json",
    "check:app": "tsc --noEmit -p tsconfig.app.json",
    "gen:api": "orval --config ./orval.config.ts",
    "gen:types": "openapi-typescript ../typespec/openapi/openapi.json -o src/api/types/openapi.ts",
    "test": "vitest --config vitest.app.config.ts",
    "test:ui": "vitest --ui --config vitest.app.config.ts",
    "test:run": "vitest run --config vitest.app.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.app.config.ts"
  },
  "dependencies": {
    "@cfreact-template/ui": "workspace:*",
    "@tanstack/react-query": "5.101.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "^7.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@tailwindcss/vite": "^4.2.4",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "orval": "^8.17.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
