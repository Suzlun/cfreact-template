{
  "name": "@cfreact-template/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/ui/styles/globals.css"
  ],
  "exports": {
    ".": "./src/app/index.ts",
    "./app": "./src/app/index.ts",
    "./api": "./src/api/index.ts",
    "./api/generated": "./src/api/generated/client.ts",
    "./api/types": "./src/api/types/index.ts",
    "./domain": "./src/domain/index.ts",
    "./domain/hooks/hello": "./src/domain/hooks/hello/index.ts",
    "./domain/hooks/users": "./src/domain/hooks/users/index.ts",
    "./ui": "./src/ui/index.ts",
    "./ui/components/ui/*": "./src/ui/components/ui/*.tsx",
    "./ui/hooks/use-mobile": "./src/ui/hooks/use-mobile.tsx",
    "./ui/hooks/use-toast": "./src/ui/hooks/use-toast.ts",
    "./ui/lib/utils": "./src/ui/lib/utils.ts",
    "./ui/styles.css": "./src/ui/styles/globals.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm check && vite build",
    "preview": "vite preview",
    "check": "pnpm check:api && pnpm check:domain && pnpm check:ui && pnpm check:app",
    "check:api": "tsc --noEmit -p tsconfig.api.json",
    "check:domain": "tsc --noEmit -p tsconfig.domain.json",
    "check:ui": "tsc --noEmit -p tsconfig.ui.json",
    "check:app": "tsc --noEmit -p tsconfig.app.json",
    "gen:api": "orval --config ./orval.config.ts",
    "gen:types": "openapi-typescript ../typespec/openapi/openapi.json -o src/api/types/openapi.ts",
    "test": "vitest --config vitest.app.config.ts",
    "test:ui": "vitest --ui --config vitest.app.config.ts",
    "test:run": "vitest run --config vitest.app.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.app.config.ts",
    "test:ui-package": "vitest --config vitest.ui.config.ts",
    "test:ui-package:run": "vitest run --config vitest.ui.config.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-aspect-ratio": "^1.1.9",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-hover-card": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-menubar": "^1.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-toggle": "^1.1.11",
    "@radix-ui/react-toggle-group": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tanstack/react-query": "5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.10",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.18.0",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.79.0",
    "react-resizable-panels": "^2.1.9",
    "react-router": "^7.17.0",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "orval": "^8.17.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
