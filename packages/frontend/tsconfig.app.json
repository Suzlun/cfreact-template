{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist/app",
    "paths": {
      "@cfreact-template/frontend": ["./src/app/index.ts"],
      "@cfreact-template/frontend/app": ["./src/app/index.ts"],
      "@cfreact-template/frontend/app/*": ["./src/app/*"],
      "@cfreact-template/frontend/api": ["./src/api/index.ts"],
      "@cfreact-template/frontend/api/*": ["./src/api/*"],
      "@cfreact-template/frontend/domain": ["./src/domain/index.ts"],
      "@cfreact-template/frontend/domain/*": ["./src/domain/*"]
    }
  },
  "include": ["src/app/**/*", "vite.config.ts", "vitest.app.config.ts"]
}
