{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist/api",
    "paths": {
      "@cfreact-template/frontend": ["./src/__forbidden__/frontend.ts"],
      "@cfreact-template/frontend/app": ["./src/__forbidden__/app.ts"],
      "@cfreact-template/frontend/app/*": ["./src/__forbidden__/app/*"],
      "@cfreact-template/frontend/api": ["./src/api/index.ts"],
      "@cfreact-template/frontend/api/*": ["./src/api/*"],
      "@cfreact-template/frontend/domain": ["./src/__forbidden__/domain.ts"],
      "@cfreact-template/frontend/domain/*": ["./src/__forbidden__/domain/*"],
      "@cfreact-template/ui": ["./src/__forbidden__/ui.ts"],
      "@cfreact-template/ui/*": ["./src/__forbidden__/ui/*"]
    }
  },
  "include": ["src/api/**/*", "orval.config.ts"]
}
