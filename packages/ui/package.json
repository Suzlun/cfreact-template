{
  "name": "@cfreact-template/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#storybook-styles": "./.storybook/storybook.css",
    "#vite-config": "./vite.config.ts"
  },
  "sideEffects": [
    "./styles/globals.css"
  ],
  "exports": {
    ".": "./index.ts",
    "./SafeHTML": "./SafeHTML.tsx",
    "./components/*": "./components/*.tsx",
    "./hooks/use-mobile": "./hooks/use-mobile.ts",
    "./lib/utils": "./lib/utils.ts",
    "./styles.css": "./styles/globals.css"
  },
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "storybook": "storybook dev --host 0.0.0.0 --port 6006 --no-open --disable-telemetry",
    "build:storybook": "storybook build --output-dir dist/storybook --disable-telemetry",
    "test": "vitest --config vitest.config.ts --project ui",
    "test:ui": "vitest --ui --config vitest.config.ts --project ui",
    "test:run": "vitest run --config vitest.config.ts --project ui",
    "test:coverage": "vitest run --coverage --config vitest.config.ts --project ui",
    "test:storybook": "vitest run --config vitest.config.ts --project storybook-light --project storybook-dark --project storybook-mobile-light --project storybook-mobile-dark"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@shadcn/react": "^0.2.1",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.10",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.79.0",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.8.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cfreact-template/build-config": "workspace:*",
    "@storybook/addon-a11y": "10.5.2",
    "@storybook/addon-docs": "10.5.2",
    "@storybook/addon-themes": "10.5.2",
    "@storybook/addon-vitest": "10.5.2",
    "@storybook/react-vite": "10.5.2",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "4.1.8",
    "jsdom": "^29.1.1",
    "storybook": "10.5.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
